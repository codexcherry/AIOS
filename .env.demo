# ─────────────────────────────────────────────────────────────────────────────
# AIOS Environment Configuration
# Copy this file to .env in the project root and fill in your values.
# None of these are required — AIOS works with defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# Model to use (must be pulled first: ollama pull <model>)
AIOS__LLM__MODEL=llama3.2:3b

# Ollama API base URL (change if running on a different host/port)
AIOS__LLM__URL=http://localhost:11434/api/generate

# Timeout in seconds for LLM calls
AIOS__LLM__TIMEOUT=60

# Max retry attempts on Ollama failure
AIOS__LLM__MAX_RETRIES=3

# ── Voice ─────────────────────────────────────────────────────────────────────
# Enable voice mode at startup (true/false)
AIOS__VOICE__ENABLED=false

# Wake word (free built-ins: jarvis, computer, terminator, porcupine,
#   blueberry, bumblebee, grapefruit, grasshopper, americano, alexa)
AIOS__VOICE__WAKE_WORD=jarvis

# Enable text-to-speech responses (true/false)
AIOS__VOICE__TTS_ENABLED=true

# TTS speech rate (words per minute, default 175)
AIOS__VOICE__TTS_RATE=175

# Picovoice access key for accurate wake-word detection
# Get a free key at: https://console.picovoice.ai/
# Leave blank to use the SpeechRecognition phrase-match fallback (no key needed)
PICOVOICE_ACCESS_KEY=your_key_here

# ── Reinforcement Learning ────────────────────────────────────────────────────
# Enable RL user adaptation (true/false)
AIOS__RL__ENABLED=true

# Max stored user corrections
AIOS__RL__MAX_CORRECTIONS=100

# Number of past examples injected into each LLM call
AIOS__RL__MAX_EXAMPLES_IN_PROMPT=5
